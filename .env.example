DATABASE_URL="postgresql://studio:studio@localhost:5433/gelocci_studio?schema=public"
WEB_ORIGIN="http://localhost:5173"
API_HOST="0.0.0.0"
API_PORT="3333"
REDIS_URL="redis://localhost:6380"
WORKFLOW_QUEUE_NAME="studio-workflow"

# LLM runtime
# Use "rule" para manter execução determinística/local.
# Use "groq", "openai" ou "anthropic" para agentes com LLM.
LLM_PROVIDER="rule"

GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-5-sonnet-latest"

LLM_TEMPERATURE="0.2"
