{
  "name": "@gelocci/studio",
  "version": "0.1.0",
  "private": true,
  "description": "Gelocci Studio — plataforma interna de agentes para evolução do ecossistema Gelocci.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "studio": "tsx src/cli/index.ts",
    "audit": "tsx src/cli/index.ts audit",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "fast-glob": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}